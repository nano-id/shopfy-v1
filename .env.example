# =============================================================================
# Shopify Support AI — environment variables
# Copy to `.env` and fill in values before running the app.
# =============================================================================

# --- Shopify (required for `shopify app dev`) ---
# From Shopify Partners → your app → Client credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# App URL shown to Shopify. During local dev this is usually the tunnel URL
# printed by `shopify app dev` (e.g. https://xxxx.trycloudflare.com).
# The CLI can update this automatically when `automatically_update_urls_on_dev` is on.
SHOPIFY_APP_URL=

# Comma-separated OAuth scopes (must match shopify.app.toml)
SCOPES=read_products,read_orders,read_customers,read_fulfillments

# --- Database (required) ---
# Use Neon, Supabase, or local PostgreSQL. Prisma runs migrations via `npm run db:push`.
# Neon example:
# DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Local example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_ai?schema=public
DATABASE_URL=

# --- Storefront widget CORS (optional) ---
# Development: leave empty — myshopify.com origins are reflected automatically.
# Production: comma-separated storefront origins, e.g.
# STOREFRONT_CORS_ORIGINS=https://your-store.myshopify.com
STOREFRONT_CORS_ORIGINS=

# --- OpenAI (optional — not required for smoke test) ---
# Milestone 3+; the app uses rule-based intent classification until this is set.
OPENAI_API_KEY=

# --- App runtime ---
NODE_ENV=development
