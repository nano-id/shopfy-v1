# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=
SCOPES=read_products,read_orders,read_customers,read_fulfillments

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/support_ai?schema=public

# Optional — Milestone 2+
OPENAI_API_KEY=

# App
NODE_ENV=development

# Optional: comma-separated allowed origins for storefront widget CORS
# STOREFRONT_CORS_ORIGINS=https://your-store.myshopify.com
